---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import EmptyState from '../../components/blog/EmptyState.astro';
import PostList from '../../components/blog/PostList.astro';
import TagFilter from '../../components/blog/TagFilter.astro';
import PageHeader from '../../components/global/PageHeader.astro';
import { tags, type TaxonomyEntry } from '../../config/taxonomy';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategoryCounts, getTagCounts } from '../../utils/blog';
import { sitePaths } from '../../utils/paths';
import { filterPublishedPosts, sortPosts } from '../../utils/posts';

interface Props {
  tag: TaxonomyEntry;
  posts: CollectionEntry<'blog'>[];
  allPosts: CollectionEntry<'blog'>[];
}

export async function getStaticPaths() {
  const allPosts = sortPosts(filterPublishedPosts(await getCollection('blog')));

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tag,
      allPosts,
      posts: allPosts.filter((post) => post.data.tags.includes(tag.displayName)),
    },
  }));
}

const { tag, posts, allPosts } = Astro.props;
const tagCounts = getTagCounts(allPosts);
const categoryCounts = getCategoryCounts(allPosts);
---

<BaseLayout title={`#${tag.displayName}`} description={`浏览带有 ${tag.displayName} 标签的文章。`}>
  <div class="page-shell taxonomy-page">
    <PageHeader
      eyebrow="Notebook / Tag"
      title={`#${tag.displayName}`}
      subtitle="独立静态标签页可直接访问、分享，并在关闭 JavaScript 时完整浏览。"
      count={posts.length}
    >
      <nav slot="breadcrumbs" aria-label="面包屑">
        <a href={sitePaths.page('/blog/')}>博客</a><span aria-hidden="true"> / </span><span>标签</span>
      </nav>
    </PageHeader>

    <TagFilter tags={tagCounts} categories={categoryCounts} selectedTag={tag.slug} />
    <div class="taxonomy-page__results">
      {posts.length > 0 ? (
        <PostList posts={posts} ariaLabel={`${tag.displayName} 标签文章`} />
      ) : (
        <EmptyState
          hidden={false}
          title="这个标签下还没有文章"
          description="标签入口已经建立，内容发布后会自动出现在这里。"
        />
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .taxonomy-page {
    padding-bottom: clamp(4rem, 9vw, 7rem);
  }

  .taxonomy-page__results {
    margin-top: var(--space-8);
  }

  nav {
    color: var(--color-text-muted);
  }
</style>
