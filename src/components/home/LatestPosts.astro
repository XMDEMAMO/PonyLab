---
import type { PostRecord } from '../../types/content';
import PostCard from '../blog/PostCard.astro';

export interface Props {
  posts: readonly PostRecord[];
  eyebrow: string;
  title: string;
  description: string;
  emptyMessage: string;
  actionLabel: string;
  actionHref: string;
}

const {
  posts,
  eyebrow,
  title,
  description,
  emptyMessage,
  actionLabel,
  actionHref,
} = Astro.props;
---

<section class="latest-posts" aria-labelledby="latest-posts-title">
  <header class="latest-posts__header">
    <div>
      <p class="latest-posts__eyebrow">{eyebrow}</p>
      <h2 id="latest-posts-title">{title}</h2>
      <p class="latest-posts__description">{description}</p>
    </div>
    <a class="latest-posts__action" href={actionHref}>{actionLabel}<span aria-hidden="true">→</span></a>
  </header>

  {posts.length > 0 ? (
    <div class="latest-posts__grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  ) : (
    <div class="latest-posts__empty">
      <span aria-hidden="true">∅</span>
      <p>{emptyMessage}</p>
      <p>文章发布后会自动按置顶和日期显示在这里，最多展示四篇。</p>
    </div>
  )}
</section>

<style>
  .latest-posts__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .latest-posts__eyebrow {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: var(--space-2);
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .latest-posts__description {
    max-width: 42rem;
    margin-top: var(--space-4);
    color: var(--color-text-muted);
  }

  .latest-posts__action {
    display: inline-flex;
    min-height: 2.8rem;
    flex: 0 0 auto;
    align-items: center;
    gap: var(--space-2);
    padding-inline: var(--space-4);
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
  }

  .latest-posts__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2rem);
    margin-top: var(--space-12);
  }

  .latest-posts__empty {
    display: grid;
    min-height: 18rem;
    place-content: center;
    margin-top: var(--space-12);
    padding: var(--space-8);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-surface) 58%, transparent);
  }

  .latest-posts__empty span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 2rem;
  }

  .latest-posts__empty p:first-of-type {
    margin-top: var(--space-3);
    color: var(--color-text);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .latest-posts__empty p:last-child {
    max-width: 34rem;
    margin-top: var(--space-2);
    color: var(--color-text-muted);
  }

  @media (max-width: 47.99rem) {
    .latest-posts__header {
      align-items: start;
      flex-direction: column;
      gap: var(--space-6);
    }

    .latest-posts__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
