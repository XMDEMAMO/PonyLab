---
import type { TerminalTypingConfig } from '../../config/home';
import TerminalTyping from './TerminalTyping.astro';

export interface Props {
  eyebrow: string;
  title: string;
  titleLines: readonly string[];
  subtitle: string;
  terminal: TerminalTypingConfig;
}

const { eyebrow, title, titleLines, subtitle, terminal } = Astro.props;
---

<div class="hero-title" data-home-reading-step="title">
  <p class="hero-title__eyebrow">{eyebrow}</p>
  <h1 aria-label={title}>
    {titleLines.map((line, index) => (
      <span>{line}{index === titleLines.length - 1 && <i aria-hidden="true">.</i>}</span>
    ))}
  </h1>
  <p class="hero-title__subtitle">{subtitle}</p>
  <TerminalTyping config={terminal} />
</div>

<style>
  .hero-title {
    width: min(100%, 35rem);
    align-self: start;
    color: var(--color-text);
    text-shadow: 0 2px 1.5rem color-mix(in srgb, var(--color-bg) 84%, transparent);
  }

  .hero-title__eyebrow {
    margin-bottom: var(--space-4);
    color: var(--color-accent-warm);
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1.2vw, 0.86rem);
    font-weight: 750;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 5ch;
    font-size: clamp(4.6rem, 10vw, 8.8rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
  }

  h1 span {
    display: block;
  }

  h1 i {
    color: var(--color-accent-warm);
    font-style: normal;
  }

  .hero-title__subtitle {
    max-width: 21rem;
    margin-block: clamp(1.5rem, 3vw, 2.25rem);
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    line-height: 1.75;
  }

  @media (max-width: 63.99rem) {
    .hero-title__subtitle {
      max-width: 13rem;
    }
  }

  @media (max-width: 47.99rem) {
    .hero-title {
      width: min(100%, 29rem);
    }

    h1 {
      font-size: clamp(4.1rem, 24vw, 7rem);
    }
  }

  @media (max-height: 38rem) and (orientation: landscape) {
    h1 {
      font-size: clamp(3.7rem, 14vh, 5.6rem);
    }

    .hero-title__subtitle {
      margin-block: var(--space-4);
    }
  }
</style>
