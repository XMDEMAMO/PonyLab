---
import { themeConfig } from '../../config/theme';
---

<button
  class="theme-controller"
  type="button"
  data-theme-controller
  data-modes={themeConfig.modes.join(',')}
  data-default-mode={themeConfig.defaultMode}
  data-storage-key={themeConfig.storageKey}
  data-color-light={themeConfig.themeColor.light}
  data-color-dark={themeConfig.themeColor.dark}
  data-label-light="浅色"
  data-label-dark="深色"
  data-label-system="跟随系统"
  aria-label="主题：跟随系统。点击切换"
  title="主题：跟随系统"
>
  <span class="theme-controller__icon" data-theme-icon="light" hidden aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18">
      <circle cx="12" cy="12" r="3.5"></circle>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path>
    </svg>
  </span>
  <span class="theme-controller__icon" data-theme-icon="dark" hidden aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18">
      <path d="M20.5 14.2A8.5 8.5 0 0 1 9.8 3.5 8.5 8.5 0 1 0 20.5 14.2Z"></path>
    </svg>
  </span>
  <span class="theme-controller__icon" data-theme-icon="system" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18">
      <rect x="3" y="4" width="18" height="13" rx="2"></rect>
      <path d="M8 21h8M12 17v4"></path>
    </svg>
  </span>
  <span class="theme-controller__label" data-theme-label>跟随系统</span>
</button>

<script>
  type ThemeMode = 'light' | 'dark' | 'system';
  type ResolvedTheme = Exclude<ThemeMode, 'system'>;

  const controller = document.querySelector<HTMLButtonElement>(
    '[data-theme-controller]',
  );

  if (controller) {
    const root = document.documentElement;
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    const modes = (controller.dataset.modes ?? 'light,dark,system').split(
      ',',
    ) as ThemeMode[];
    const defaultMode = (controller.dataset.defaultMode ?? 'system') as ThemeMode;
    const storageKey = controller.dataset.storageKey ?? 'ponylab-theme';
    const labels: Record<ThemeMode, string> = {
      light: controller.dataset.labelLight ?? '浅色',
      dark: controller.dataset.labelDark ?? '深色',
      system: controller.dataset.labelSystem ?? '跟随系统',
    };
    const colors: Record<ResolvedTheme, string> = {
      light: controller.dataset.colorLight ?? '#E7F0F2',
      dark: controller.dataset.colorDark ?? '#111A21',
    };

    const isThemeMode = (value: string | undefined | null): value is ThemeMode =>
      value === 'light' || value === 'dark' || value === 'system';
    const resolveTheme = (mode: ThemeMode): ResolvedTheme =>
      mode === 'system' ? (mediaQuery.matches ? 'dark' : 'light') : mode;

    const applyTheme = (mode: ThemeMode, persist: boolean): void => {
      const resolvedTheme = resolveTheme(mode);
      root.dataset.themeMode = mode;
      root.dataset.theme = resolvedTheme;
      document
        .querySelector<HTMLMetaElement>('meta[name="theme-color"]')
        ?.setAttribute('content', colors[resolvedTheme]);

      const label = labels[mode];
      controller.dataset.currentMode = mode;
      controller.setAttribute('aria-label', `主题：${label}。点击切换`);
      controller.title = `主题：${label}`;
      const labelElement = controller.querySelector<HTMLElement>(
        '[data-theme-label]',
      );
      if (labelElement) labelElement.textContent = label;
      controller.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => {
        icon.hidden = icon.dataset.themeIcon !== mode;
      });

      if (persist) {
        try {
          window.localStorage.setItem(storageKey, mode);
        } catch {
          // Theme still applies when storage is unavailable.
        }
      }
    };

    const initialMode = isThemeMode(root.dataset.themeMode)
      ? root.dataset.themeMode
      : defaultMode;
    applyTheme(initialMode, false);

    controller.addEventListener('click', () => {
      const currentMode = isThemeMode(root.dataset.themeMode)
        ? root.dataset.themeMode
        : defaultMode;
      const currentIndex = Math.max(0, modes.indexOf(currentMode));
      const nextMode = modes[(currentIndex + 1) % modes.length] ?? defaultMode;
      applyTheme(nextMode, true);
    });

    mediaQuery.addEventListener('change', () => {
      if (root.dataset.themeMode === 'system') applyTheme('system', false);
    });

    window.addEventListener('storage', (event) => {
      if (event.key === storageKey && isThemeMode(event.newValue)) {
        applyTheme(event.newValue, false);
      }
    });
  }
</script>

<style>
  .theme-controller {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.75rem;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .theme-controller:hover {
    border-color: color-mix(in srgb, var(--color-accent) 62%, var(--color-border));
    background: var(--color-surface-strong);
  }

  .theme-controller__icon {
    flex: 0 0 auto;
  }

  .theme-controller__icon svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-controller__label {
    font-size: 0.8rem;
    white-space: nowrap;
  }

  @media (max-width: 29.99rem) {
    .theme-controller {
      width: 2.5rem;
      justify-content: center;
      padding-inline: 0;
    }

    .theme-controller__label {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .theme-controller:hover {
      transform: translateY(-1px);
    }
  }
</style>
