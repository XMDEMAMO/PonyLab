<div
  class="home-scroll-scene"
  data-home-scroll-scene
  data-home-scroll-mode="natural"
  data-home-scroll-stage="all"
  data-home-motion-state="natural"
  data-home-scroll-intent="0"
>
  <div class="home-scroll-scene__sticky" data-home-scroll-visual>
    <slot />
  </div>
</div>

<script>
  import {
    advanceHomeScrollIntent,
    deriveHomeScrollProgress,
    getHomeScrollState,
    shouldUseNaturalHomeScroll,
    type HomeScrollIntentResult,
  } from '../../utils/home-scroll';
  import { registerClientLifecycle } from '../../utils/client-lifecycle';

  registerClientLifecycle('home-scroll-scene', () => {
    const root = document.querySelector<HTMLElement>('[data-home-scroll-scene]');
    const sticky = root?.querySelector<HTMLElement>('[data-home-scroll-visual]');
    const profileLayer = root?.querySelector<HTMLElement>('[data-home-profile-layer]');

    if (root && sticky) {
    const controller = new AbortController();
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const shortViewport = window.matchMedia(
      '(max-height: 38rem) and (orientation: landscape)',
    );
    const navigatorWithMemory = navigator as Navigator & { deviceMemory?: number };
    const pullThreshold = 260;
    const intentResetDelay = 260;
    const profileSnapProgress = 0.48;
    let frameId = 0;
    let intentState: HomeScrollIntentResult = {
      amount: 0,
      direction: null,
      committed: null,
    };
    let intentTimer = 0;
    let motionTimer = 0;

    const setProfileAvailability = (available: boolean) => {
      if (!profileLayer) return;

      profileLayer.toggleAttribute('inert', !available);
      profileLayer.setAttribute('aria-hidden', String(!available));
    };

    const clearIntentTimer = () => {
      window.clearTimeout(intentTimer);
      intentTimer = 0;
    };

    const clearMotionTimer = () => {
      window.clearTimeout(motionTimer);
      motionTimer = 0;
    };

    const resetIntent = () => {
      clearIntentTimer();
      intentState = { amount: 0, direction: null, committed: null };
      root.dataset.homeScrollIntent = '0';
    };

    const setMotionState = (
      motion: 'natural' | 'intro' | 'pulling' | 'rebounding' | 'docking' | 'profile' | 'retreating' | 'content',
    ) => {
      root.dataset.homeMotionState = motion;

      if (motion === 'natural') {
        root.dataset.homeScrollStage = 'all';
        setProfileAvailability(true);
        return;
      }

      if (motion === 'docking' || motion === 'profile') {
        root.dataset.homeScrollStage = '2';
        setProfileAvailability(motion === 'profile');
        return;
      }

      if (motion === 'content') {
        root.dataset.homeScrollStage = '3';
        setProfileAvailability(false);
        return;
      }

      root.dataset.homeScrollStage = '1';
      setProfileAvailability(false);
    };

    const getScrollTarget = (progress: number) => {
      const rootBox = root.getBoundingClientRect();
      const stickyBox = sticky.getBoundingClientRect();
      const stickyTop = Number.parseFloat(getComputedStyle(sticky).top) || 0;
      const rootTop = window.scrollY + rootBox.top;
      const travel = Math.max(0, rootBox.height - stickyBox.height);

      return rootTop - stickyTop + (travel * progress);
    };

    const snapToProgress = (progress: number) => {
      window.scrollTo(0, getScrollTarget(progress));
    };

    const commitProfile = () => {
      resetIntent();
      clearMotionTimer();
      setMotionState('docking');
      snapToProgress(profileSnapProgress);
      motionTimer = window.setTimeout(() => {
        setMotionState('profile');
        motionTimer = 0;
      }, 2460);
    };

    const retreatToIntro = () => {
      resetIntent();
      clearMotionTimer();
      setMotionState('retreating');
      snapToProgress(0);
      motionTimer = window.setTimeout(() => {
        setMotionState('intro');
        motionTimer = 0;
      }, 820);
    };

    const scheduleIntentRebound = () => {
      clearIntentTimer();
      intentTimer = window.setTimeout(() => {
        if (root.dataset.homeMotionState !== 'pulling') {
          resetIntent();
          return;
        }

        setMotionState('rebounding');
        intentTimer = window.setTimeout(() => {
          resetIntent();
          setMotionState('intro');
        }, 430);
      }, intentResetDelay);
    };

    const updateState = () => {
      frameId = 0;

      if (root.dataset.homeScrollMode !== 'enhanced') return;

      const rootBox = root.getBoundingClientRect();
      const stickyBox = sticky.getBoundingClientRect();
      const progress = deriveHomeScrollProgress({
        rootTop: rootBox.top,
        rootHeight: rootBox.height,
        stickyTop: Number.parseFloat(getComputedStyle(sticky).top) || stickyBox.top,
        stickyHeight: stickyBox.height,
      });
      const state = getHomeScrollState(progress);

      root.style.setProperty('--home-scroll-progress', state.progress.toFixed(4));
      root.style.setProperty('--home-hero-exit', state.heroExit.toFixed(4));

      const motion = root.dataset.homeMotionState;
      if (motion === 'pulling' || motion === 'rebounding' || motion === 'docking' || motion === 'retreating') {
        return;
      }

      if (state.stage === 3) {
        setMotionState('content');
      } else if (state.stage === 2) {
        setMotionState('profile');
      } else {
        setMotionState('intro');
      }
    };

    const scheduleUpdate = () => {
      if (frameId || root.dataset.homeScrollMode !== 'enhanced') return;
      frameId = window.requestAnimationFrame(updateState);
    };

    const applyMode = () => {
      const natural = shouldUseNaturalHomeScroll({
        reducedMotion: reducedMotion.matches,
        shortViewport: shortViewport.matches,
        hardwareConcurrency: navigator.hardwareConcurrency,
        deviceMemory: navigatorWithMemory.deviceMemory,
      });

      if (natural) {
        resetIntent();
        clearMotionTimer();
        root.dataset.homeScrollMode = 'natural';
        root.removeAttribute('style');
        setMotionState('natural');
        return;
      }

      root.dataset.homeScrollMode = 'enhanced';
      updateState();
    };

    const normalizeWheelDelta = (event: WheelEvent) => {
      const scale = event.deltaMode === WheelEvent.DOM_DELTA_LINE
        ? 16
        : event.deltaMode === WheelEvent.DOM_DELTA_PAGE
          ? window.innerHeight
          : 1;

      return Math.sign(event.deltaY) * Math.min(96, Math.abs(event.deltaY * scale));
    };

    const onWheel = (event: WheelEvent) => {
      if (root.dataset.homeScrollMode !== 'enhanced' || event.deltaY === 0) return;

      const motion = root.dataset.homeMotionState;
      if (motion === 'docking' || motion === 'retreating' || motion === 'rebounding') {
        event.preventDefault();
        return;
      }

      const stage = root.dataset.homeScrollStage;
      const isForwardPull = stage === '1' && event.deltaY > 0;
      const isBackwardPull = stage === '2' && event.deltaY < 0;

      if (!isForwardPull && !isBackwardPull) {
        resetIntent();
        return;
      }

      event.preventDefault();
      intentState = advanceHomeScrollIntent(
        intentState,
        normalizeWheelDelta(event),
        pullThreshold,
      );
      root.dataset.homeScrollIntent = String(Math.round(intentState.amount));

      if (intentState.committed === 'forward' && stage === '1') {
        commitProfile();
        return;
      }

      if (intentState.committed === 'backward' && stage === '2') {
        retreatToIntro();
        return;
      }

      if (stage === '1') {
        setMotionState('pulling');
      }
      scheduleIntentRebound();
    };

    const onKeydown = (event: KeyboardEvent) => {
      if (root.dataset.homeScrollMode !== 'enhanced') return;

      const rootBox = root.getBoundingClientRect();
      const isActive = rootBox.top < window.innerHeight && rootBox.bottom > 0;
      if (!isActive) return;

      const forwardKeys = ['ArrowDown', 'PageDown', ' '];
      const backwardKeys = ['ArrowUp', 'PageUp'];

      if (root.dataset.homeScrollStage === '1' && forwardKeys.includes(event.key)) {
        event.preventDefault();
        commitProfile();
      } else if (root.dataset.homeScrollStage === '2' && backwardKeys.includes(event.key)) {
        event.preventDefault();
        retreatToIntro();
      }
    };

    window.addEventListener('scroll', scheduleUpdate, { passive: true, signal: controller.signal });
    window.addEventListener('resize', scheduleUpdate, { passive: true, signal: controller.signal });
    window.addEventListener('wheel', onWheel, { passive: false, signal: controller.signal });
    window.addEventListener('keydown', onKeydown, { signal: controller.signal });
    reducedMotion.addEventListener('change', applyMode, { signal: controller.signal });
    shortViewport.addEventListener('change', applyMode, { signal: controller.signal });
    applyMode();

    return () => {
      controller.abort();
      clearIntentTimer();
      clearMotionTimer();
      if (frameId) window.cancelAnimationFrame(frameId);
    };
    }

    return undefined;
  });
</script>

<style>
  .home-scroll-scene {
    --home-scroll-progress: 0;
    --home-hero-exit: 0;
    position: relative;
  }

  .home-scroll-scene[data-home-scroll-mode='enhanced'] {
    height: 260svh;
  }

  .home-scroll-scene[data-home-scroll-mode='enhanced'] .home-scroll-scene__sticky {
    position: sticky;
    top: var(--site-header-height);
    height: calc(100svh - var(--site-header-height));
    min-height: 36rem;
    overflow: clip;
    opacity: calc(1 - (var(--home-hero-exit) * 0.22));
    transform: translate3d(0, calc(var(--home-hero-exit) * -3vh), 0);
    transform-origin: center top;
    will-change: opacity, transform;
  }

  .home-scroll-scene[data-home-scroll-mode='enhanced']
    .home-scroll-scene__sticky
    :global(.home-hero) {
    height: 100%;
    min-height: 100%;
  }

  @media (max-width: 47.99rem) {
    .home-scroll-scene[data-home-scroll-mode='enhanced'] {
      height: 225svh;
    }

    .home-scroll-scene[data-home-scroll-mode='enhanced'] .home-scroll-scene__sticky {
      transform: translate3d(0, calc(var(--home-hero-exit) * -2vh), 0);
    }
  }

  @media (prefers-reduced-motion: reduce),
    (max-height: 38rem) and (orientation: landscape) {
    .home-scroll-scene[data-home-scroll-mode='enhanced'] {
      height: auto;
    }

    .home-scroll-scene[data-home-scroll-mode='enhanced'] .home-scroll-scene__sticky {
      position: relative;
      top: auto;
      height: auto;
      min-height: 0;
      overflow: visible;
      opacity: 1;
      transform: none;
      will-change: auto;
    }
  }
</style>
