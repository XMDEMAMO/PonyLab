<aside class="scroll-progress" data-scroll-progress-control hidden aria-label="页面滚动辅助">
  <button type="button" data-scroll-jump="top" aria-label="跳到页面顶部">↑</button>
  <div
    class="scroll-progress__track"
    role="progressbar"
    aria-label="页面阅读进度"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
    data-scroll-progress
  >
    <span aria-hidden="true"></span>
  </div>
  <button type="button" data-scroll-jump="bottom" aria-label="跳到页面底部">↓</button>
</aside>

<script>
  import { registerClientLifecycle } from '../../utils/client-lifecycle';

  registerClientLifecycle('scroll-progress-control', () => {
    const root = document.querySelector<HTMLElement>('[data-scroll-progress-control]');
    const progress = root?.querySelector<HTMLElement>('[data-scroll-progress]');
    const top = root?.querySelector<HTMLButtonElement>('[data-scroll-jump="top"]');
    const bottom = root?.querySelector<HTMLButtonElement>('[data-scroll-jump="bottom"]');
    if (!root || !progress) return undefined;

    const controller = new AbortController();
    const fineDesktop = matchMedia('(min-width: 64rem) and (hover: hover) and (pointer: fine)');
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)');
    let frame = 0;

    const update = (): void => {
      frame = 0;
      const scrolling = document.scrollingElement ?? document.documentElement;
      const range = Math.max(0, scrolling.scrollHeight - window.innerHeight);
      const eligible =
        fineDesktop.matches &&
        window.innerHeight >= 480 &&
        range > window.innerHeight * 0.5 &&
        !document.documentElement.classList.contains('is-dialog-open');
      root.hidden = !eligible;
      if (!eligible) return;

      const value = range > 0 ? Math.min(100, Math.max(0, (window.scrollY / range) * 100)) : 0;
      progress.style.setProperty('--scroll-progress-value', `${value}%`);
      progress.setAttribute('aria-valuenow', String(Math.round(value)));
    };

    const schedule = (): void => {
      if (!frame) frame = requestAnimationFrame(update);
    };

    const scrollTo = (position: ScrollLogicalPosition): void => {
      const scrolling = document.scrollingElement ?? document.documentElement;
      window.scrollTo({
        top: position === 'start' ? 0 : scrolling.scrollHeight,
        behavior: reducedMotion.matches ? 'auto' : 'smooth',
      });
    };

    window.addEventListener('scroll', schedule, { passive: true, signal: controller.signal });
    window.addEventListener('resize', schedule, { passive: true, signal: controller.signal });
    window.addEventListener('load', schedule, { once: true, signal: controller.signal });
    window.addEventListener('ponylab:modal-open', schedule, { signal: controller.signal });
    fineDesktop.addEventListener('change', schedule, { signal: controller.signal });
    top?.addEventListener('click', () => scrollTo('start'), { signal: controller.signal });
    bottom?.addEventListener('click', () => scrollTo('end'), { signal: controller.signal });

    const resizeObserver = new ResizeObserver(schedule);
    resizeObserver.observe(document.body);
    update();

    return () => {
      controller.abort();
      resizeObserver.disconnect();
      if (frame) cancelAnimationFrame(frame);
    };
  });
</script>

<style>
  .scroll-progress {
    position: fixed;
    z-index: 35;
    top: 50%;
    right: max(var(--space-4), env(safe-area-inset-right));
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-surface-strong) 86%, transparent);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(0.7rem);
    transform: translateY(-50%);
  }

  .scroll-progress[hidden] { display: none; }

  button {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    padding: 0;
    color: var(--color-text-muted);
    border: 0;
    border-radius: 50%;
    background: transparent;
  }

  .scroll-progress__track {
    position: relative;
    width: 0.25rem;
    height: min(24vh, 10rem);
    overflow: clip;
    border-radius: var(--radius-pill);
    background: var(--color-border);
  }

  .scroll-progress__track span {
    position: absolute;
    inset: auto 0 0;
    height: var(--scroll-progress-value, 0%);
    border-radius: inherit;
    background: var(--color-accent-warm);
  }

  @media (max-width: 63.99rem), (hover: none), (pointer: coarse) {
    .scroll-progress { display: none; }
  }

  @media print {
    .scroll-progress { display: none; }
  }
</style>
