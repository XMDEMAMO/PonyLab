---
export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  items: readonly { label: string; value: string }[];
}

const { eyebrow, title, description, items } = Astro.props;
---

<section class="current-status" aria-labelledby="current-status-title">
  <header>
    <p>{eyebrow}</p>
    <h2 id="current-status-title">{title}</h2>
    <span>{description}</span>
  </header>

  <div class="current-status__terminal">
    <div class="current-status__chrome" aria-hidden="true">
      <span></span><span></span><span></span>
      <p>ponylab://status/now</p>
    </div>
    <dl>
      {items.map((item, index) => (
        <div>
          <dt><span aria-hidden="true">0{index + 1}</span>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .current-status {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(22rem, 1.25fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 6rem);
  }

  header > p {
    color: var(--color-accent-warm);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.045em;
  }

  header > span {
    display: block;
    max-width: 40rem;
    margin-top: var(--space-4);
    color: var(--color-text-muted);
  }

  .current-status__terminal {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, transparent);
    box-shadow: var(--shadow-card);
  }

  .current-status__chrome {
    display: grid;
    grid-template-columns: repeat(3, 0.58rem) 1fr;
    align-items: center;
    gap: 0.42rem;
    min-height: 2.8rem;
    padding-inline: var(--space-4);
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .current-status__chrome > span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 50%;
    background: var(--color-accent-secondary);
  }

  .current-status__chrome > span:first-child { background: var(--color-accent-warm); }
  .current-status__chrome > span:last-of-type { background: var(--color-accent); }

  .current-status__chrome p {
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-align: right;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  dl { display: grid; }

  dl div {
    display: grid;
    grid-template-columns: minmax(8rem, 0.42fr) minmax(0, 1fr);
    gap: var(--space-4);
    padding: var(--space-5, 1.25rem) var(--space-6);
  }

  dl div + div { border-top: 1px solid var(--color-border); }

  dt {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  dt span {
    color: var(--color-accent-warm);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  dd { overflow-wrap: anywhere; font-weight: 700; }

  @media (max-width: 47.99rem) {
    .current-status { grid-template-columns: 1fr; }
  }

  @media (max-width: 25rem) {
    dl div { grid-template-columns: 1fr; }
  }
</style>
