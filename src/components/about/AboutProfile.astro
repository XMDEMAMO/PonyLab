---
import { Image } from 'astro:assets';

import type { SocialLink } from '../../config/site';
import { isSafeExternalUrl } from '../../utils/links';

export interface Props {
  author: {
    name: string;
    bio: string;
    avatar: ImageMetadata;
    avatarAlt: string;
  };
  role: string;
  location: string;
  note: string;
  socials: readonly SocialLink[];
}

const { author, role, location, note, socials } = Astro.props;
---

<section class="about-profile" aria-labelledby="about-profile-title">
  <div class="about-profile__portrait">
    <Image
      src={author.avatar}
      alt={author.avatarAlt}
      widths={[240, 360, 480]}
      sizes="(max-width: 48rem) 11rem, 18rem"
      format="webp"
      quality={80}
      loading="eager"
    />
    <span aria-hidden="true">PONY / ID</span>
  </div>

  <div class="about-profile__content">
    <p class="about-profile__eyebrow">Profile record / 001</p>
    <h2 id="about-profile-title">{author.name}</h2>
    <p class="about-profile__role">{role}</p>
    <p class="about-profile__bio">{author.bio}</p>
    <p class="about-profile__note">{note}</p>

    <dl>
      <div>
        <dt>Location</dt>
        <dd>{location}</dd>
      </div>
      <div>
        <dt>Base</dt>
        <dd>PonyLab</dd>
      </div>
    </dl>

    <div class="about-profile__socials" aria-label="社交链接">
      {socials.map((social) => isSafeExternalUrl(social.href) ? (
        <a href={social.href} target="_blank" rel="noopener noreferrer">
          {social.label}<span aria-hidden="true">↗</span>
          <span class="visually-hidden">（在新窗口打开）</span>
        </a>
      ) : (
        <span>{social.label}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .about-profile {
    display: grid;
    grid-template-columns: minmax(15rem, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1.5rem, 5vw, 4.5rem);
    padding: clamp(1.25rem, 4vw, 2.5rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 13%, transparent), transparent 55%),
      color-mix(in srgb, var(--color-surface) 86%, transparent);
    box-shadow: var(--shadow-card);
  }

  .about-profile__portrait {
    position: relative;
    min-height: 22rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.3rem);
    background: var(--color-bg-elevated);
  }

  .about-profile__portrait::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgb(7 17 24 / 58%));
    content: '';
    pointer-events: none;
  }

  .about-profile__portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-profile__portrait > span {
    position: absolute;
    z-index: 1;
    right: var(--space-4);
    bottom: var(--space-4);
    color: #edf5f7;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
  }

  .about-profile__content {
    display: flex;
    min-width: 0;
    justify-content: center;
    flex-direction: column;
    padding-block: var(--space-4);
  }

  .about-profile__eyebrow {
    color: var(--color-accent-warm);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 4.2rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .about-profile__role {
    margin-top: var(--space-3);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .about-profile__bio,
  .about-profile__note {
    max-width: 60ch;
    margin-top: var(--space-5, 1.25rem);
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .about-profile__note {
    padding: var(--space-4);
    border-left: 0.2rem solid var(--color-accent);
    background: color-mix(in srgb, var(--color-bg-elevated) 64%, transparent);
  }

  dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  dl div {
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 60%, transparent);
  }

  dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  dd { margin-top: var(--space-1); overflow-wrap: anywhere; }

  .about-profile__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .about-profile__socials a,
  .about-profile__socials > span {
    display: inline-flex;
    min-height: 2.65rem;
    align-items: center;
    gap: var(--space-2);
    padding-inline: var(--space-4);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-bg-elevated);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  .about-profile__socials > span { color: var(--color-text-muted); }

  @media (max-width: 47.99rem) {
    .about-profile { grid-template-columns: 1fr; }
    .about-profile__portrait { min-height: 18rem; }
  }

  @media (max-width: 25rem) {
    dl { grid-template-columns: 1fr; }
  }
</style>
