---
import { getImage } from 'astro:assets';

import type { HomeHeroSceneConfig } from '../../config/home';

export interface Props {
  scenes: {
    light: HomeHeroSceneConfig;
    dark: HomeHeroSceneConfig;
  };
}

interface OptimizedScene {
  avifSrcSet: string;
  webpSrc: string;
  webpSrcSet: string;
}

const { scenes } = Astro.props;
const responsiveWidths = [640, 960, 1280, 1600, 1920, 2560];

async function optimizeScene(
  scene: HomeHeroSceneConfig,
): Promise<OptimizedScene> {
  const widths = responsiveWidths.filter((width) => width <= scene.src.width);
  const fallbackWidth = Math.min(1920, scene.src.width);
  const sharedOptions = {
    src: scene.src,
    width: fallbackWidth,
    widths,
    sizes: '100vw',
  } as const;
  const [avif, webp] = await Promise.all([
    getImage({ ...sharedOptions, format: 'avif', quality: 58 }),
    getImage({ ...sharedOptions, format: 'webp', quality: 74 }),
  ]);

  return {
    avifSrcSet: avif.srcSet.attribute,
    webpSrc: webp.src,
    webpSrcSet: webp.srcSet.attribute,
  };
}

const [lightOptimized, darkOptimized] = await Promise.all([
  optimizeScene(scenes.light),
  optimizeScene(scenes.dark),
]);
const transparentPlaceholder =
  'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%221%22 height=%221%22/%3E';
---

<div
  class="home-hero-scene"
  data-home-hero-scene
  data-active-theme="light"
>
  <picture
    class="home-hero-scene__picture home-hero-scene__picture--managed"
    hidden
  >
    <source
      type="image/avif"
      data-home-hero-source="avif"
      data-srcset-light={lightOptimized.avifSrcSet}
      data-srcset-dark={darkOptimized.avifSrcSet}
    />
    <source
      type="image/webp"
      data-home-hero-source="webp"
      data-srcset-light={lightOptimized.webpSrcSet}
      data-srcset-dark={darkOptimized.webpSrcSet}
    />
    <img
      src={transparentPlaceholder}
      alt=""
      width={scenes.light.src.width}
      height={scenes.light.src.height}
      sizes="100vw"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      data-home-hero-image
      data-src-light={lightOptimized.webpSrc}
      data-src-dark={darkOptimized.webpSrc}
      data-srcset-light={lightOptimized.webpSrcSet}
      data-srcset-dark={darkOptimized.webpSrcSet}
      data-alt-light={scenes.light.alt}
      data-alt-dark={scenes.dark.alt}
    />
  </picture>

  <noscript>
    <picture class="home-hero-scene__picture" data-home-hero-noscript>
      <source type="image/avif" srcset={lightOptimized.avifSrcSet} sizes="100vw" />
      <source type="image/webp" srcset={lightOptimized.webpSrcSet} sizes="100vw" />
      <img
        src={lightOptimized.webpSrc}
        srcset={lightOptimized.webpSrcSet}
        sizes="100vw"
        alt={scenes.light.alt}
        width={scenes.light.src.width}
        height={scenes.light.src.height}
        loading="eager"
        decoding="async"
      />
    </picture>
  </noscript>
</div>

<script is:inline>
  (() => {
    const scene = document.querySelector('[data-home-hero-scene]');
    const managedPicture = scene?.querySelector('.home-hero-scene__picture--managed');
    const image = scene?.querySelector('[data-home-hero-image]');
    const sources = scene?.querySelectorAll('[data-home-hero-source]');

    if (
      !(scene instanceof HTMLElement) ||
      !(managedPicture instanceof HTMLPictureElement) ||
      !(image instanceof HTMLImageElement) ||
      !sources
    ) {
      return;
    }

    const applyThemeSource = () => {
      const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

      sources.forEach((source) => {
        if (source instanceof HTMLSourceElement) {
          source.srcset = source.dataset[`srcset${theme[0].toUpperCase()}${theme.slice(1)}`] ?? '';
        }
      });

      const themeKey = `${theme[0].toUpperCase()}${theme.slice(1)}`;
      image.srcset = image.dataset[`srcset${themeKey}`] ?? '';
      image.src = image.dataset[`src${themeKey}`] ?? '';
      image.alt = image.dataset[`alt${themeKey}`] ?? '';
      scene.dataset.activeTheme = theme;
    };

    applyThemeSource();
    managedPicture.hidden = false;
    new MutationObserver(applyThemeSource).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>

<style define:vars={{
  lightDesktopPosition: scenes.light.desktopObjectPosition,
  lightMobilePosition: scenes.light.mobileObjectPosition,
  lightMaskStrength: scenes.light.maskStrength,
  darkDesktopPosition: scenes.dark.desktopObjectPosition,
  darkMobilePosition: scenes.dark.mobileObjectPosition,
  darkMaskStrength: scenes.dark.maskStrength,
}}>
  .home-hero-scene {
    --scene-desktop-position: var(--lightDesktopPosition);
    --scene-mobile-position: var(--lightMobilePosition);
    --scene-mask-strength: var(--lightMaskStrength);
    position: absolute;
    z-index: 0;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    background: var(--color-bg);
  }

  :global(html[data-theme='dark']) .home-hero-scene {
    --scene-desktop-position: var(--darkDesktopPosition);
    --scene-mobile-position: var(--darkMobilePosition);
    --scene-mask-strength: var(--darkMaskStrength);
  }

  .home-hero-scene::after {
    position: absolute;
    z-index: 1;
    inset: 0;
    content: '';
    opacity: var(--scene-mask-strength);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-bg) 96%, transparent) 0%,
        color-mix(in srgb, var(--color-bg) 68%, transparent) 27%,
        transparent 58%,
        color-mix(in srgb, var(--color-bg) 58%, transparent) 100%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-bg) 48%, transparent) 0%,
        transparent 38%,
        color-mix(in srgb, var(--color-bg) 82%, transparent) 100%
      );
  }

  .home-hero-scene__picture,
  .home-hero-scene__picture :global(img) {
    width: 100%;
    height: 100%;
  }

  .home-hero-scene__picture {
    display: block;
  }

  .home-hero-scene__picture--managed[hidden] {
    display: none;
  }

  .home-hero-scene__picture :global(img) {
    max-width: none;
    object-fit: cover;
    object-position: var(--scene-desktop-position);
    transform: none;
    filter: none;
  }

  @media (max-width: 47.99rem) {
    .home-hero-scene::after {
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--color-bg) 84%, transparent) 0%,
          color-mix(in srgb, var(--color-bg) 24%, transparent) 34%,
          transparent 52%,
          color-mix(in srgb, var(--color-bg) 92%, transparent) 100%
        ),
        linear-gradient(
          90deg,
          color-mix(in srgb, var(--color-bg) 48%, transparent),
          transparent 50%,
          color-mix(in srgb, var(--color-bg) 40%, transparent)
        );
    }

    .home-hero-scene__picture :global(img) {
      object-position: var(--scene-mobile-position);
    }
  }
</style>
