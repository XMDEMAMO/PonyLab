---
import type { ProjectRecord } from '../../types/showcase';
import ProjectCard from './ProjectCard.astro';

export interface Props {
  projects: readonly ProjectRecord[];
}

const { projects } = Astro.props;
---

{projects.length === 0 ? (
  <div class="project-empty" data-project-empty role="status">
    <p>项目记录还在准备中</p>
    <span>这里会在数据补充后显示项目卡片。</span>
  </div>
) : (
  <div class="project-grid" data-project-grid role="list">
    {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
  </div>
)}

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  .project-empty {
    display: grid;
    min-height: 14rem;
    place-content: center;
    gap: var(--space-2);
    padding: var(--space-8);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
  }

  .project-empty p {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 750;
  }

  .project-empty span { color: var(--color-text-muted); }

  @media (max-width: 63.99rem) {
    .project-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 39.99rem) {
    .project-grid { grid-template-columns: minmax(0, 1fr); }
  }
</style>
