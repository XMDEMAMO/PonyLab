---
import type { ArchiveYear } from '../../utils/blog';
import { formatContentDate, toArticlePath } from '../../utils/posts';

export interface Props {
  groups: readonly ArchiveYear[];
}

const { groups } = Astro.props;
---

<div class="archive-list">
  {groups.map((group) => (
    <section class="archive-year" aria-labelledby={`archive-${group.year}`}>
      <h2 id={`archive-${group.year}`}>{group.year}</h2>
      <div class="archive-year__months">
        {group.months.map((month) => (
          <section class="archive-month" aria-labelledby={`archive-${group.year}-${month.month}`}>
            <h3 id={`archive-${group.year}-${month.month}`}>{month.label}</h3>
            <ol>
              {month.posts.map((post) => (
                <li>
                  <time datetime={post.data.pubDate.toISOString()}>{formatContentDate(post.data.pubDate)}</time>
                  <a href={toArticlePath(post.id)}>{post.data.title}</a>
                  <span>{post.data.category}</span>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </section>
  ))}
</div>

<style>
  .archive-list,
  .archive-year__months {
    display: grid;
    gap: var(--space-8);
  }

  .archive-year {
    display: grid;
    grid-template-columns: minmax(5rem, 0.25fr) minmax(0, 1fr);
    gap: var(--space-8);
  }

  .archive-year > h2 {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
  }

  .archive-month {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: var(--space-4);
  }

  .archive-month h3 {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  ol {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr) auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  time,
  li span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  li a {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 47.99rem) {
    .archive-year,
    .archive-month {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    li {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
