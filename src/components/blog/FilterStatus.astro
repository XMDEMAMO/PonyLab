---
import { sitePaths } from '../../utils/paths';

export interface Props {
  total: number;
}

const { total } = Astro.props;
---

<div class="filter-status">
  <p data-filter-status aria-live="polite">
    {total > 0 ? `共 ${total} 篇文章，启用 JavaScript 后可在本页筛选和分页。` : '暂时还没有已发布文章。'}
  </p>
  <div class="filter-status__actions">
    <a href={sitePaths.page('/blog/')} data-filter-clear hidden>清空筛选</a>
    <button type="button" data-filter-copy hidden>复制当前链接</button>
  </div>
</div>

<style>
  .filter-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-4);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    font-size: 0.9rem;
  }

  .filter-status__actions {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  a,
  button {
    min-height: 2.35rem;
    padding: 0.4rem 0.8rem;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: transparent;
  }

  @media (max-width: 39.99rem) {
    .filter-status {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
