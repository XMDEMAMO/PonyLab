---
import { Image } from 'astro:assets';

import { categories, getTaxonomyByName, tags } from '../../config/taxonomy';
import type { PostRecord } from '../../types/content';
import type { ReadingTimeResult } from '../../utils/reading-time';
import { sitePaths } from '../../utils/paths';
import { formatContentDate } from '../../utils/posts';

export interface Props {
  post: PostRecord;
  readingTime: ReadingTimeResult;
}

const { post, readingTime } = Astro.props;
const category = getTaxonomyByName(categories, post.data.category);
const postTags = post.data.tags.flatMap((name) => {
  const tag = getTaxonomyByName(tags, name);
  return tag ? [tag] : [];
});
---

<header class="article-header">
  <nav class="article-header__breadcrumbs" aria-label="面包屑">
    <a href={sitePaths.page('/')}>首页</a>
    <span aria-hidden="true">/</span>
    <a href={sitePaths.page('/blog/')}>博客</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">文章</span>
  </nav>

  <p class="article-header__eyebrow">Notebook / Article</p>
  <h1>{post.data.title}</h1>
  <p class="article-header__description">{post.data.description}</p>

  <div class="article-header__meta" aria-label="文章信息">
    <time datetime={post.data.pubDate.toISOString()}>
      发布于 {formatContentDate(post.data.pubDate)}
    </time>
    {post.data.updatedDate && (
      <time datetime={post.data.updatedDate.toISOString()}>
        更新于 {formatContentDate(post.data.updatedDate)}
      </time>
    )}
    <span>{readingTime.label}</span>
    {category && (
      <a href={sitePaths.page(`/categories/${category.slug}/`)}>{category.displayName}</a>
    )}
  </div>

  {postTags.length > 0 && (
    <ul class="article-header__tags" role="list" aria-label="文章标签">
      {postTags.map((tag) => (
        <li><a href={sitePaths.page(`/tags/${tag.slug}/`)}>#{tag.displayName}</a></li>
      ))}
    </ul>
  )}

  {post.data.cover && (
    <figure class="article-header__cover">
      <Image
        src={post.data.cover}
        alt={post.data.coverAlt ?? ''}
        widths={[720, 1080, 1440]}
        sizes="(max-width: 64rem) calc(100vw - 2rem), 70rem"
        layout="full-width"
        format="webp"
        quality={76}
        loading="eager"
      />
    </figure>
  )}
</header>

<style>
  .article-header {
    max-width: 70rem;
    margin-inline: auto;
    padding-block: clamp(3.5rem, 8vw, 6.5rem) clamp(2.5rem, 5vw, 4rem);
  }

  .article-header__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  .article-header__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .article-header__eyebrow {
    margin-top: var(--space-8);
    color: var(--color-accent-warm);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 18ch;
    margin-top: var(--space-4);
    font-size: clamp(2.35rem, 7vw, 5.4rem);
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .article-header__description {
    max-width: 52rem;
    margin-top: var(--space-6);
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.8;
  }

  .article-header__meta,
  .article-header__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-5);
    margin-top: var(--space-6);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .article-header__meta a,
  .article-header__tags a {
    color: inherit;
    text-decoration: none;
  }

  .article-header__meta > *:not(:last-child)::after {
    margin-left: var(--space-5);
    color: var(--color-border-strong);
    content: '·';
  }

  .article-header__tags {
    gap: var(--space-2);
  }

  .article-header__tags a {
    display: block;
    padding: 0.32rem 0.72rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-surface) 68%, transparent);
  }

  .article-header__cover {
    margin-top: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }

  .article-header__cover :global(img) {
    width: 100%;
    max-height: 36rem;
    object-fit: cover;
  }

  @media (hover: hover) and (pointer: fine) {
    .article-header__breadcrumbs a:hover,
    .article-header__meta a:hover,
    .article-header__tags a:hover {
      color: var(--color-text);
    }
  }
</style>
