---
import { siteConfig, type SocialLink } from '../../config/site';

const year = new Date().getFullYear();

function hasHref(link: SocialLink): link is SocialLink & { href: string } {
  return typeof link.href === 'string';
}

const socialLinks: readonly SocialLink[] = siteConfig.socials;
const availableSocialLinks = socialLinks.filter(hasHref);
---

<footer class="site-footer">
  <div class="site-footer__inner page-shell">
    <p>© {year} {siteConfig.footer.copyrightName}</p>
    <p>{siteConfig.footer.note}</p>
    {
      availableSocialLinks.length > 0 && (
        <nav aria-label="社交链接">
          <ul role="list">
            {availableSocialLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 70%, transparent);
  }

  .site-footer__inner {
    display: flex;
    min-height: 6rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-6);
    padding-block: var(--space-6);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .site-footer ul {
    display: flex;
    gap: var(--space-4);
  }

  @media (max-width: 35rem) {
    .site-footer__inner {
      align-content: center;
      justify-content: flex-start;
    }
  }
</style>
