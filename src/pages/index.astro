---
import { getCollection } from 'astro:content';

import HomeHeroScene from '../components/home/HomeHeroScene.astro';
import HomeScrollScene from '../components/home/HomeScrollScene.astro';
import HeroTitle from '../components/home/HeroTitle.astro';
import HomeSectionTransition from '../components/home/HomeSectionTransition.astro';
import LatestPosts from '../components/home/LatestPosts.astro';
import ProfileCard from '../components/home/ProfileCard.astro';
import SiteStats from '../components/home/SiteStats.astro';
import { homeConfig } from '../config/home';
import { siteConfig } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomePostStats, selectHomePosts } from '../utils/home';
import { sitePaths } from '../utils/paths';

const allPosts = await getCollection('blog');
const latestPosts = selectHomePosts(allPosts, homeConfig.latestPostCount);
const postStats = getHomePostStats(allPosts);
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.description}
  backgroundMode="home"
  pageClass="home-page"
>
  <HomeScrollScene>
    <section class="home-hero" aria-label="PonyLab 首页主视觉">
      <HomeHeroScene scenes={homeConfig.heroScenes} />
      <div class="home-hero__content page-shell">
        <div class="home-hero__title" data-home-title-layer>
          <HeroTitle
            eyebrow={homeConfig.eyebrow}
            title={homeConfig.title}
            titleLines={homeConfig.titleLines}
            subtitle={homeConfig.subtitle}
            typingLines={homeConfig.typingLines}
          />
        </div>
        <div class="home-hero__profile" data-home-profile-layer>
          <ProfileCard
            author={siteConfig.author}
            statusLabel={homeConfig.profile.statusLabel}
            statusText={homeConfig.profile.statusText}
            actionLabel={homeConfig.profile.actionLabel}
            actionHref={sitePaths.page(homeConfig.profile.actionHref)}
          />
        </div>
      </div>
    </section>
  </HomeScrollScene>

  <HomeSectionTransition />

  <div class="home-content page-shell" data-home-reading-step="content">
    <LatestPosts
      posts={latestPosts}
      eyebrow={homeConfig.latestPosts.eyebrow}
      title={homeConfig.latestPosts.title}
      description={homeConfig.latestPosts.description}
      emptyMessage={homeConfig.latestPosts.emptyMessage}
      actionLabel={homeConfig.latestPosts.actionLabel}
      actionHref={sitePaths.page(homeConfig.latestPosts.actionHref)}
    />

    <SiteStats
      eyebrow={homeConfig.stats.eyebrow}
      title={homeConfig.stats.title}
      postCount={postStats.postCount}
      tagCount={postStats.tagCount}
      postLabel={homeConfig.stats.postLabel}
      tagLabel={homeConfig.stats.tagLabel}
    />
  </div>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: max(44rem, calc(100svh - var(--site-header-height)));
    overflow: clip;
    isolation: isolate;
    border-bottom: 1px solid var(--color-border);
  }

  .home-hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: max(44rem, calc(100svh - var(--site-header-height)));
    grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.75fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    padding-block: clamp(3rem, 7vh, 5.5rem);
  }

  .home-hero__title,
  .home-hero__profile {
    min-width: 0;
  }

  :global([data-home-scroll-mode='enhanced']) .home-hero__title {
    opacity: calc(1 - var(--home-title-exit));
    transform: translate3d(0, calc(var(--home-title-exit) * -1.75rem), 0);
    will-change: opacity, transform;
  }

  .home-hero__profile {
    align-self: start;
    padding-top: clamp(2rem, 8vh, 6rem);
  }

  :global([data-home-scroll-mode='enhanced']) .home-hero__profile {
    opacity: var(--home-profile-enter);
    transform: translate3d(
      calc((1 - var(--home-profile-enter)) * 2rem),
      calc((1 - var(--home-profile-enter)) * 3.5rem),
      0
    );
    will-change: opacity, transform;
  }

  .home-content {
    display: grid;
    gap: clamp(5rem, 10vw, 8rem);
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  @media (max-width: 63.99rem) {
    .home-hero__content {
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.7fr);
      gap: var(--space-8);
    }
  }

  @media (max-width: 47.99rem) {
    .home-hero,
    .home-hero__content {
      min-height: max(60rem, calc(100svh - var(--site-header-height)));
    }

    .home-hero__content {
      grid-template-columns: 1fr;
      align-content: space-between;
      gap: clamp(11rem, 34vh, 20rem);
      padding-block: clamp(2rem, 6vh, 4rem);
    }

    .home-hero__profile {
      align-self: end;
      padding-top: 0;
    }

    :global([data-home-scroll-mode='enhanced']) .home-hero__content {
      height: 100%;
      min-height: 100%;
      grid-template-rows: minmax(0, 1fr);
      align-content: stretch;
      gap: 0;
    }

    :global([data-home-scroll-mode='enhanced']) .home-hero__title,
    :global([data-home-scroll-mode='enhanced']) .home-hero__profile {
      grid-area: 1 / 1;
    }

    :global([data-home-scroll-mode='enhanced']) .home-hero__title {
      align-self: start;
    }

    :global([data-home-scroll-mode='enhanced']) .home-hero__profile {
      align-self: start;
      padding-top: var(--space-6);
      transform: translate3d(
        0,
        calc((1 - var(--home-profile-enter)) * 2.5rem),
        0
      );
    }

    :global(html[data-theme='dark'])
      :global([data-home-scroll-mode='enhanced'])
      .home-hero__profile {
      align-self: end;
      padding-block: 0 var(--space-6);
    }
  }

  @media (max-height: 38rem) and (orientation: landscape) {
    .home-hero,
    .home-hero__content {
      min-height: 42rem;
    }

    .home-hero__content {
      align-items: start;
      padding-block: var(--space-8);
    }

    .home-hero__profile {
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__title,
    .home-hero__profile {
      opacity: 1;
      transform: none;
      will-change: auto;
    }
  }
</style>
